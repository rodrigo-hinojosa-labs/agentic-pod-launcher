#!/usr/bin/env bash
# agentctl — host-side CLI wrapper for the most common docker exec commands
# against a scaffolded agent container. Replaces the long `docker exec -it
# -u agent NAME ...` invocations littered across NEXT_STEPS and docs with
# short subcommands.
#
# Resolves the container name from (in order):
#   1. -a NAME  flag
#   2. AGENT_NAME env var
#   3. yq '.agent.name' agent.yml  (in $PWD, falls back to script dir)
#
# Example: ./scripts/agentctl attach        # tmux attach with retry-loop
#          ./scripts/agentctl status        # heartbeatctl status proxy
#          ./scripts/agentctl logs -f       # tail -f /workspace/claude.log
#          ./scripts/agentctl doctor        # full system diagnostic
#
# Style and exit codes mirror docker/scripts/heartbeatctl: 0=ok,
# 1=validation/usage, 2=operational error.

set -u -o pipefail

AGENTCTL_NAME_OVERRIDE=""

while [ $# -gt 0 ]; do
  case "$1" in
    -a|--agent)
      AGENTCTL_NAME_OVERRIDE="${2:-}"
      [ -z "$AGENTCTL_NAME_OVERRIDE" ] && {
        echo "agentctl: -a/--agent requires a NAME argument" >&2
        exit 1
      }
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

# Source yaml lib for `yaml_require_yq` — agentctl uses `yq -r` directly
# (resolve_agent_name, doctor's parse checks, etc.), so a Debian apt-installed
# yq 3.x or python-yq would silently fail. yaml_require_yq vendors a v4 binary
# into scripts/vendor/bin/ and prepends it to PATH.
__agentctl_dir="$(cd "$(dirname "$0")" && pwd)"
for __agentctl_yaml in \
    "$__agentctl_dir/lib/yaml.sh" \
    "$__agentctl_dir/../scripts/lib/yaml.sh"; do
  if [ -f "$__agentctl_yaml" ]; then
    # shellcheck disable=SC1090
    source "$__agentctl_yaml"
    break
  fi
done
unset __agentctl_dir __agentctl_yaml
if command -v yaml_require_yq &>/dev/null; then
  yaml_require_yq || exit 1
fi

resolve_agent_name() {
  if [ -n "$AGENTCTL_NAME_OVERRIDE" ]; then
    printf '%s\n' "$AGENTCTL_NAME_OVERRIDE"
    return 0
  fi
  if [ -n "${AGENT_NAME:-}" ]; then
    printf '%s\n' "$AGENT_NAME"
    return 0
  fi
  local probe
  for probe in "./agent.yml" "$(dirname "$0")/../agent.yml"; do
    if [ -f "$probe" ]; then
      local val
      val=$(yq -r '.agent.name' "$probe" 2>/dev/null)
      if [ -n "$val" ] && [ "$val" != "null" ]; then
        printf '%s\n' "$val"
        return 0
      fi
    fi
  done
  echo "agentctl: cannot resolve agent name." >&2
  echo "  Pass -a NAME, set AGENT_NAME, or run from a workspace with agent.yml." >&2
  exit 1
}

# _require_docker — friendly bail-out when the Docker daemon isn't reachable.
# Most subcommands need to talk to docker; calling this once at the top of
# each one keeps the error message consistent and actionable instead of
# leaking the raw "Cannot connect to the Docker daemon" trace.
_require_docker() {
  if ! docker info >/dev/null 2>&1; then
    echo "agentctl: cannot reach the Docker daemon." >&2
    echo "" >&2
    if [ "$(uname -s)" = "Darwin" ]; then
      echo "  • macOS: open Docker Desktop (Cmd+Space → \"Docker\") and wait ~30s." >&2
    else
      echo "  • Linux: sudo systemctl start docker" >&2
    fi
    echo "" >&2
    echo "Then retry." >&2
    exit 2
  fi
}

# ─── Doctor helpers ──────────────────────────────────────────────────────

_doctor_warn_count=0
_doctor_fail_count=0

_doctor_pass() { echo "  ✓ $1"; }
_doctor_warn() {
  echo "  ⚠ $1"
  [ -n "${2:-}" ] && echo "    → $2"
  _doctor_warn_count=$((_doctor_warn_count + 1))
}
_doctor_fail() {
  echo "  ✗ $1"
  [ -n "${2:-}" ] && echo "    → $2"
  _doctor_fail_count=$((_doctor_fail_count + 1))
}
_doctor_skip() { echo "  ⊝ $1 (skipped — $2)"; }

# Convert an ISO 8601 UTC timestamp ("2026-05-02T03:30:00Z") to epoch
# seconds. Tries GNU date (Linux) first, then BSD date (macOS).
# Empty/invalid input → empty stdout.
_epoch_from_iso() {
  local ts="$1"
  [ -z "$ts" ] && return 0
  if date -d "$ts" +%s 2>/dev/null; then return 0; fi
  date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null || true
}

# Render a delta in seconds as a human-readable string ("47s", "12m",
# "23h", "4d"). Coarse-grained on purpose — doctor output is meant to be
# scannable.
_humanize_delta() {
  local s="$1"
  if   [ "$s" -lt 60 ];     then echo "${s}s"
  elif [ "$s" -lt 3600 ];   then echo "$((s/60))m"
  elif [ "$s" -lt 86400 ];  then echo "$((s/3600))h"
  else                           echo "$((s/86400))d"
  fi
}

# Doctor check for one backup branch. Reads
# <workspace>/scripts/heartbeat/<name>-backup.json and reports:
#   - ⚠ when the file is missing or has no last_push (never pushed)
#   - ⚠ when the last push is older than max_hours
#   - ✓ when fresh enough
# $1 = backup name (identity|vault|config), $2 = max age in hours.
_check_backup_freshness() {
  local agent="$1" name="$2" max_hours="$3"
  local state_file="$WORKSPACE/scripts/heartbeat/${name}-backup.json"
  local label
  case "$name" in
    identity) label="Backup identity" ;;
    vault)    label="Backup vault" ;;
    config)   label="Backup config" ;;
    *)        label="Backup $name" ;;
  esac

  if [ ! -f "$state_file" ]; then
    _doctor_warn "$label: never pushed yet" "agentctl heartbeat backup-$name"
    return
  fi

  local last_push
  last_push=$(jq -r '.last_push // ""' "$state_file" 2>/dev/null)
  if [ -z "$last_push" ]; then
    _doctor_warn "$label: state file present but no last_push timestamp" "agentctl heartbeat backup-$name"
    return
  fi

  local then now delta delta_max human
  then=$(_epoch_from_iso "$last_push")
  now=$(date -u +%s)
  if [ -z "$then" ]; then
    _doctor_warn "$label: could not parse last_push '$last_push'"
    return
  fi
  delta=$((now - then))
  # Compare in seconds to keep sub-hour overrides (e.g.
  # DOCTOR_IDENTITY_MAX_AGE_HOURS=0 in tests) meaningful.
  delta_max=$((max_hours * 3600))
  human=$(_humanize_delta "$delta")

  # Identity has an extra 'mode' field worth surfacing.
  local extra=""
  if [ "$name" = "identity" ]; then
    local mode
    mode=$(jq -r '.mode // ""' "$state_file" 2>/dev/null)
    [ -n "$mode" ] && extra=" ($mode mode)"
  fi

  if [ "$delta" -gt "$delta_max" ]; then
    _doctor_warn "$label: pushed ${human} ago — stale (>${max_hours}h)${extra}" \
      "agentctl heartbeat backup-$name (or check the cron + GitHub token)"
  else
    _doctor_pass "$label: pushed ${human} ago${extra}"
  fi
}

# Doctor check for one token-health probe. Reads
# <workspace>/scripts/heartbeat/token-health/<id>.json and reports the
# probe outcome:
#   - ⚠ when the file is missing (probe never ran)
#   - ⚠ when last_check is older than max_age_hours
#   - ✗ when status is auth_fail (token expired/revoked)
#   - ⚠ when status is network (transient — degrade not fatal)
#   - ⊝ when status is skipped (token not configured for this kind)
#   - ✓ when status is ok
# $1 = id slug (e.g. "github", "telegram", "atlassian-work"),
# $2 = label shown in output, $3 = max_hours threshold for staleness.
_check_token_health() {
  local id="$1" label="$2" max_hours="$3"
  local state_file="$WORKSPACE/scripts/heartbeat/token-health/${id}.json"

  if [ ! -f "$state_file" ]; then
    _doctor_warn "$label: never probed yet" "agentctl heartbeat token-check"
    return
  fi

  local status last_check error latency http_code
  status=$(jq -r '.status // ""' "$state_file" 2>/dev/null)
  last_check=$(jq -r '.last_check // ""' "$state_file" 2>/dev/null)
  error=$(jq -r '.error // ""' "$state_file" 2>/dev/null)
  latency=$(jq -r '.latency_ms // 0' "$state_file" 2>/dev/null)
  http_code=$(jq -r '.http_code // ""' "$state_file" 2>/dev/null)

  if [ -z "$status" ] || [ -z "$last_check" ]; then
    _doctor_warn "$label: state file present but malformed" "agentctl heartbeat token-check"
    return
  fi

  local then now delta delta_max human
  then=$(_epoch_from_iso "$last_check")
  now=$(date -u +%s)
  if [ -z "$then" ]; then
    _doctor_warn "$label: could not parse last_check '$last_check'"
    return
  fi
  delta=$((now - then))
  delta_max=$((max_hours * 3600))
  human=$(_humanize_delta "$delta")

  if [ "$delta" -gt "$delta_max" ]; then
    _doctor_warn "$label: last probe ${human} ago — stale (>${max_hours}h)" \
      "agentctl heartbeat token-check (or check the cron is running)"
    return
  fi

  case "$status" in
    ok)
      _doctor_pass "$label: ok (probed ${human} ago, ${latency}ms)"
      ;;
    auth_fail)
      _doctor_fail "$label: auth-fail (HTTP ${http_code}, probed ${human} ago)" \
        "Regenerate the token, update .env, then ./setup.sh --regenerate"
      ;;
    network)
      _doctor_warn "$label: network error (${error}, probed ${human} ago)" \
        "Likely transient. Check container has outbound HTTPS."
      ;;
    skipped)
      _doctor_skip "$label" "${error:-token not configured}"
      ;;
    *)
      _doctor_warn "$label: unknown status '$status'"
      ;;
  esac
}

# Resolve the absolute path to the agent's workspace on the host. Used
# by freshness checks to read state files via the bind-mount instead of
# round-tripping through 'docker exec cat'. Falls back to cwd when
# agent.yml is in the current directory.
_resolve_workspace() {
  local agent="$1"
  if [ -f "./agent.yml" ]; then
    pwd -P
    return
  fi
  # docker inspect to find the bind-mount source path
  docker inspect --format \
    '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' \
    "$agent" 2>/dev/null
}

# Helper: run a command inside the container as agent, capture stdout.
_in_container() {
  local agent="$1"; shift
  docker exec -u agent "$agent" "$@" 2>/dev/null
}

cmd_doctor() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  echo "agentctl doctor — diagnosing $agent"
  echo ""

  # 1. Docker daemon
  if docker info >/dev/null 2>&1; then
    _doctor_pass "Docker daemon running"
  else
    if [ "$(uname -s)" = "Darwin" ]; then
      _doctor_fail "Docker daemon unreachable" "Open Docker Desktop and wait ~30s, then retry"
    else
      _doctor_fail "Docker daemon unreachable" "sudo systemctl start docker, then retry"
    fi
    echo ""
    echo "Issues found: $_doctor_fail_count error(s), $_doctor_warn_count warning(s)."
    exit 2
  fi

  # 2. Container exists
  local container_id
  container_id=$(docker ps -a -q --filter "name=^${agent}$" 2>/dev/null)
  if [ -z "$container_id" ]; then
    _doctor_fail "Container '$agent' does not exist" "agentctl up"
    echo ""
    echo "Issues found: $_doctor_fail_count error(s), $_doctor_warn_count warning(s)."
    exit 2
  fi

  # 3. Container running
  local status uptime
  status=$(docker inspect --format '{{.State.Status}}' "$agent" 2>/dev/null)
  if [ "$status" != "running" ]; then
    _doctor_fail "Container '$agent' status: $status" "agentctl up"
    echo ""
    echo "Skipping in-container checks (container not running)."
    echo ""
    echo "Issues found: $_doctor_fail_count error(s), $_doctor_warn_count warning(s)."
    exit 2
  fi
  uptime=$(docker inspect --format '{{.State.StartedAt}}' "$agent" 2>/dev/null | head -c 19)
  _doctor_pass "Container '$agent' running (started $uptime)"

  # 4. Container health
  local health
  health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$agent" 2>/dev/null)
  case "$health" in
    healthy)   _doctor_pass "Container health: healthy" ;;
    starting)  _doctor_warn "Container health: still starting" "Healthcheck still in start_period (~60s). Re-run doctor in a minute." ;;
    unhealthy) _doctor_fail "Container health: unhealthy" "Check 'agentctl logs -n 50' and 'docker logs $agent | tail -50'" ;;
    none)      _doctor_warn "Container health: not configured" "Older agent without HEALTHCHECK in docker-compose.yml. Re-scaffold or add it manually." ;;
    *)         _doctor_warn "Container health: $health" ;;
  esac

  # 5. agent.yml valid (host-side check; file is in cwd or workspace)
  local yml=""
  for probe in "./agent.yml" "$(dirname "$0")/../agent.yml"; do
    [ -f "$probe" ] && { yml="$probe"; break; }
  done
  if [ -z "$yml" ]; then
    _doctor_warn "agent.yml not found" "Run from the workspace dir, or pass -a NAME to skip this check"
  elif yq -e '.' "$yml" >/dev/null 2>&1; then
    _doctor_pass "agent.yml is valid"
  else
    _doctor_fail "agent.yml is malformed (yq parse failed)" "Restore from agent.yml.prev if available, or re-run setup.sh"
  fi

  # 6. .env present and 0600 (host-side)
  local env_file
  env_file=$(dirname "${yml:-./agent.yml}")/.env
  if [ -f "$env_file" ]; then
    local perms
    perms=$(stat -f '%Lp' "$env_file" 2>/dev/null || stat -c '%a' "$env_file" 2>/dev/null)
    if [ "$perms" = "600" ]; then
      _doctor_pass ".env present (0600)"
    else
      _doctor_warn ".env permissions are $perms (should be 600)" "chmod 600 $env_file"
    fi
  else
    _doctor_warn ".env not found at $env_file" "Re-run setup.sh --regenerate"
  fi

  # 7. tmux session 'agent' alive (in-container, via pgrep — works without
  #    user-scoped tmux socket access)
  if _in_container "$agent" pgrep -f "tmux .*-s agent" >/dev/null; then
    _doctor_pass "tmux session 'agent' alive"
  else
    _doctor_warn "tmux session 'agent' not found" "Watchdog respawns every 2s. Wait 5s and re-run; if it persists, agentctl restart"
  fi

  # 8. crond running
  if _in_container "$agent" pgrep -x crond >/dev/null; then
    local crond_pid
    crond_pid=$(_in_container "$agent" pgrep -x crond)
    _doctor_pass "crond alive (PID $crond_pid)"
  else
    _doctor_fail "crond is not running" "agentctl restart (heartbeat won't fire without crond)"
  fi

  # 9. Telegram plugin running (only if notifications.channel=telegram)
  local notif_channel=""
  [ -n "$yml" ] && notif_channel=$(yq -r '.notifications.channel' "$yml" 2>/dev/null)
  if [ "$notif_channel" = "telegram" ]; then
    if _in_container "$agent" pgrep -f "bun server.ts" >/dev/null; then
      local bun_pid
      bun_pid=$(_in_container "$agent" pgrep -f "bun server.ts")
      _doctor_pass "Telegram plugin running (PID $bun_pid)"
    else
      _doctor_fail "Telegram plugin (bun server.ts) is not running" "agentctl heartbeat kick-channel"
    fi
  else
    _doctor_skip "Telegram plugin" "notifications.channel=$notif_channel"
  fi

  # 10. Heartbeat last run
  local hb_enabled=""
  [ -n "$yml" ] && hb_enabled=$(yq -r '.features.heartbeat.enabled' "$yml" 2>/dev/null)
  if [ "$hb_enabled" = "true" ]; then
    local hb_status
    hb_status=$(_in_container "$agent" sh -c 'cat /workspace/scripts/heartbeat/logs/state.json 2>/dev/null | jq -r ".last_run.status // empty"' 2>/dev/null)
    case "$hb_status" in
      ok)
        local hb_at hb_ms
        hb_at=$(_in_container "$agent" sh -c 'cat /workspace/scripts/heartbeat/logs/state.json | jq -r ".last_run.ended_at"' 2>/dev/null)
        hb_ms=$(_in_container "$agent" sh -c 'cat /workspace/scripts/heartbeat/logs/state.json | jq -r ".last_run.duration_ms"' 2>/dev/null)
        _doctor_pass "Heartbeat last run: ok @ $hb_at (${hb_ms}ms)"
        ;;
      "")
        _doctor_warn "Heartbeat enabled but no run recorded yet" "Wait for the first cron tick, or trigger one with 'agentctl heartbeat test'"
        ;;
      *)
        _doctor_fail "Heartbeat last run: $hb_status" "agentctl logs -n 100 ; agentctl heartbeat logs"
        ;;
    esac
  else
    _doctor_skip "Heartbeat" "features.heartbeat.enabled=$hb_enabled"
  fi

  # 11. Vault skeleton seeded (only if vault.enabled)
  local vault_enabled=""
  [ -n "$yml" ] && vault_enabled=$(yq -r '.vault.enabled' "$yml" 2>/dev/null)
  if [ "$vault_enabled" = "true" ]; then
    if _in_container "$agent" test -f /home/agent/.vault/CLAUDE.md; then
      _doctor_pass "Vault skeleton seeded at /home/agent/.vault"
    else
      _doctor_fail "Vault is enabled but skeleton missing" "agentctl restart (entrypoint seeds it on boot if dir is empty)"
    fi
  else
    _doctor_skip "Vault" "vault.enabled=$vault_enabled"
  fi

  # 12. Telegram plugin patched
  if [ "$notif_channel" = "telegram" ]; then
    local plugin_dir
    plugin_dir=$(_in_container "$agent" sh -c 'ls -d /home/agent/.claude/plugins/cache/claude-plugins-official/telegram/*/server.ts 2>/dev/null | head -1')
    if [ -n "$plugin_dir" ]; then
      local typing_v3 offset stderr primary
      typing_v3=$(_in_container "$agent" grep -c "typing refresh patch v3" "$plugin_dir" 2>/dev/null || echo 0)
      offset=$(_in_container "$agent" grep -c "offset persistence patch v1" "$plugin_dir" 2>/dev/null || echo 0)
      stderr=$(_in_container "$agent" grep -c "stderr-capture patch v1" "$plugin_dir" 2>/dev/null || echo 0)
      primary=$(_in_container "$agent" grep -c "primary lock patch v1" "$plugin_dir" 2>/dev/null || echo 0)
      if [ "$typing_v3" -ge 1 ] && [ "$offset" -ge 1 ] && [ "$stderr" -ge 1 ] && [ "$primary" -ge 1 ]; then
        _doctor_pass "Telegram plugin patches: typing v3, offset v1, stderr v1, primary v1"
      else
        _doctor_warn "Telegram plugin patches incomplete (typing=$typing_v3 offset=$offset stderr=$stderr primary=$primary)" "agentctl restart (apply_telegram_typing_patch.py runs at boot)"
      fi
    else
      _doctor_skip "Telegram plugin patches" "plugin not yet installed in cache"
    fi
  else
    _doctor_skip "Telegram plugin patches" "notifications.channel=$notif_channel"
  fi

  # 13-15. Backup freshness — read the state files from the bind-mounted
  # workspace and warn when last_push is stale or never happened. The
  # thresholds default to 2× the expected cadence (identity 48h, vault
  # 25h, config 8d). Override via env vars for one-off invocations.
  WORKSPACE=$(_resolve_workspace "$agent")
  if [ -z "$WORKSPACE" ] || [ ! -d "$WORKSPACE/scripts/heartbeat" ]; then
    _doctor_skip "Backup freshness" "could not locate workspace bind-mount"
  else
    local id_max="${DOCTOR_IDENTITY_MAX_AGE_HOURS:-48}"
    local vault_max="${DOCTOR_VAULT_MAX_AGE_HOURS:-25}"
    local config_max_days="${DOCTOR_CONFIG_MAX_AGE_DAYS:-8}"
    local config_max=$((config_max_days * 24))
    _check_backup_freshness "$agent" identity "$id_max"
    _check_backup_freshness "$agent" vault "$vault_max"
    _check_backup_freshness "$agent" config "$config_max"
  fi

  # 16-18. Token health — read state files written by the hourly
  # check_token_health.sh cron and surface auth failures (token expired
  # or revoked) before the user notices via a broken Claude tool call.
  # github + telegram are single tokens; atlassian loops by workspace
  # because each fork has its own state file (atlassian-work, atlassian-personal).
  if [ -n "$WORKSPACE" ] && [ -d "$WORKSPACE/scripts/heartbeat" ]; then
    local th_max="${DOCTOR_TOKEN_MAX_AGE_HOURS:-2}"
    local th_dir="$WORKSPACE/scripts/heartbeat/token-health"
    if [ -d "$th_dir" ]; then
      [ -f "$th_dir/github.json" ] \
        && _check_token_health github "Token github" "$th_max"
      [ -f "$th_dir/telegram.json" ] \
        && _check_token_health telegram "Token telegram" "$th_max"
      local atl_file
      for atl_file in "$th_dir"/atlassian-*.json; do
        [ -f "$atl_file" ] || continue
        local atl_id atl_name
        atl_id=$(basename "$atl_file" .json)
        atl_name="${atl_id#atlassian-}"
        _check_token_health "$atl_id" "Token atlassian-$atl_name" "$th_max"
      done
    fi
  fi

  echo ""
  if [ "$_doctor_fail_count" -eq 0 ] && [ "$_doctor_warn_count" -eq 0 ]; then
    echo "All checks passed."
    exit 0
  elif [ "$_doctor_fail_count" -eq 0 ]; then
    echo "$_doctor_warn_count warning(s). Re-run after addressing the hints above."
    exit 1
  else
    echo "$_doctor_fail_count error(s), $_doctor_warn_count warning(s)."
    exit 2
  fi
}

cmd_help() {
  cat <<'HELP_EOF'
agentctl — wrapper for the most common ops against a scaffolded agent.

Usage: agentctl [-a NAME] <subcommand> [args]

Diagnostic:
  doctor                   full system diagnostic (Docker → container → MCPs)

Container/lifecycle:
  up                       docker compose up -d
  start                    alias of `up`
  stop                     docker compose down
  restart                  docker compose restart
  ps                       docker compose ps

Interactive:
  attach [--no-retry]      tmux attach -t agent (retry-loop by default)
  shell [--root]           bash inside the container (as agent, or root)
  run <cmd...>             arbitrary command via docker exec -u agent NAME

Observability:
  logs [-f] [-n N]         tail [-f] [-n N] /workspace/claude.log
  logs --stderr            tail of telegram-mcp-stderr.log (forensic)
  status                   heartbeatctl status (pretty)
  mcp [list]               claude mcp list

Heartbeat (proxy to in-container heartbeatctl):
  heartbeat <sub> [args]   passes through; e.g. `heartbeat pause`, `heartbeat set-interval 5m`

Misc:
  -a NAME / --agent NAME   override resolved agent name (otherwise: AGENT_NAME env, or yq agent.yml)
  --help                   this help

Examples:
  agentctl doctor                  # diagnose every subsystem at once
  agentctl attach                  # connects via retry-loop
  agentctl logs -f                 # follow claude.log
  agentctl heartbeat status        # delegated to heartbeatctl
  agentctl run ls /workspace       # ad-hoc command
HELP_EOF
}

cmd_attach() {
  local agent retry=true
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  case "${1:-}" in
    --no-retry) retry=false ;;
  esac
  if [ "$retry" = "true" ]; then
    local i
    for i in $(seq 15); do
      docker exec -it -u agent "$agent" tmux attach -t agent && return 0
      sleep 1
    done
    echo "agentctl: tmux 'agent' session never appeared after 15s." >&2
    echo "  Check: agentctl doctor" >&2
    exit 2
  else
    exec docker exec -it -u agent "$agent" tmux attach -t agent
  fi
}

cmd_shell() {
  local agent root=false
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  case "${1:-}" in
    --root) root=true ;;
  esac
  if [ "$root" = "true" ]; then
    exec docker exec -it "$agent" bash
  else
    exec docker exec -it -u agent "$agent" bash
  fi
}

cmd_run() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  if [ $# -eq 0 ]; then
    echo "agentctl run: missing command" >&2
    exit 1
  fi
  exec docker exec -u agent "$agent" "$@"
}

cmd_logs() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  case "${1:-}" in
    --stderr)
      shift
      exec docker exec -u agent "$agent" tail "$@" /workspace/scripts/heartbeat/logs/telegram-mcp-stderr.log
      ;;
    *)
      exec docker exec -u agent "$agent" tail "$@" /workspace/claude.log
      ;;
  esac
}

cmd_status() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  exec docker exec -u agent "$agent" heartbeatctl status
}

cmd_heartbeat() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  if [ $# -eq 0 ]; then
    echo "agentctl heartbeat: missing subcommand (try 'agentctl heartbeat help')" >&2
    exit 1
  fi
  exec docker exec -u agent "$agent" heartbeatctl "$@"
}

cmd_mcp() {
  local agent
  agent=$(resolve_agent_name) || exit $?
  _require_docker
  exec docker exec -u agent "$agent" claude mcp "${@:-list}"
}

cmd_compose() {
  _require_docker
  exec docker compose "$@"
}

cmd_up() { cmd_compose up -d; }
cmd_start() { cmd_up; }
cmd_stop() { cmd_compose down; }
cmd_restart() { cmd_compose restart; }
cmd_ps() { cmd_compose ps; }

main() {
  local sub="${1:-help}"
  shift || true
  case "$sub" in
    help|--help|-h) cmd_help ;;
    doctor) cmd_doctor "$@" ;;
    attach) cmd_attach "$@" ;;
    shell) cmd_shell "$@" ;;
    run) cmd_run "$@" ;;
    logs) cmd_logs "$@" ;;
    status) cmd_status "$@" ;;
    heartbeat) cmd_heartbeat "$@" ;;
    mcp) cmd_mcp "$@" ;;
    up) cmd_up ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
    restart) cmd_restart ;;
    ps) cmd_ps ;;
    *)
      echo "agentctl: unknown subcommand '$sub'. Try 'agentctl help'." >&2
      exit 1
      ;;
  esac
}

main "$@"
