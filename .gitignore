# Files generated by setup.sh (ignored from version control)
/CLAUDE.md
/agent.yml
/.env
/.mcp.json

# Heartbeat runtime
/scripts/heartbeat/logs/
/scripts/heartbeat/heartbeat.conf

# Docker mode runtime introspection (refreshed every container boot)
/CONTAINER.md
/claude.log
/claude.cron.log

# Auto-downloaded dependencies
/scripts/vendor/bin/

# Agent state (login, pairing, sessions, plugin cache) — bind-mounted to
# /home/agent inside the container. Contains OAuth tokens and Telegram
# credentials, must NEVER be committed.
/.state/

# Tooling
node_modules/
.DS_Store
*.tmp
*.swp

# Claude Code repo config — track shared commands/skills, ignore user-local settings
/.claude/settings.json
/.claude/settings.local.json

# Git worktrees
/.worktrees/

# Personal scratch directories that the user keeps inside this repo
# folder but are not part of the launcher source. Defensive — never
# commit these by accident.
/obsidean-feature/
/Agentic Pod Lanuncher/
