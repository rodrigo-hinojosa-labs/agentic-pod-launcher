#!/usr/bin/env bash
# heartbeatctl — inspect, control, and mutate the heartbeat.
# Image-baked, workspace-reading. Spec: docs/superpowers/specs/2026-04-19-*.md

set -u

# Overridable paths for tests.
WORKSPACE="${HEARTBEATCTL_WORKSPACE:-/workspace}"
HEARTBEAT_DIR="$WORKSPACE/scripts/heartbeat"
AGENT_YML="$WORKSPACE/agent.yml"
CONF_FILE="$HEARTBEAT_DIR/heartbeat.conf"
STATE_FILE="$HEARTBEAT_DIR/state.json"
RUNS_FILE="$HEARTBEAT_DIR/logs/runs.jsonl"
# Default: write the "desired" crontab to a workspace staging file.
# entrypoint.sh runs a root-privileged sync loop that copies it to
# /etc/crontabs/agent — busybox crond refuses to load crontabs not
# owned by root, so agent cannot write /etc/crontabs/ directly.
# Tests override HEARTBEATCTL_CRONTAB_FILE to a tmp path and inspect
# it directly (no sync loop needed in test context).
CRONTAB_FILE="${HEARTBEATCTL_CRONTAB_FILE:-$HEARTBEAT_DIR/.crontab.staging}"
LIB_DIR="${HEARTBEATCTL_LIB_DIR:-/opt/agent-admin/scripts/lib}"

# shellcheck source=/dev/null
[ -f "$LIB_DIR/interval.sh" ] && source "$LIB_DIR/interval.sh"
# shellcheck source=/dev/null
[ -f "$LIB_DIR/state.sh" ]    && source "$LIB_DIR/state.sh"
# shellcheck source=/dev/null
[ -f "$LIB_DIR/backup_identity.sh" ] && source "$LIB_DIR/backup_identity.sh"
# shellcheck source=/dev/null
[ -f "$LIB_DIR/backup_vault.sh" ]    && source "$LIB_DIR/backup_vault.sh"
# shellcheck source=/dev/null
[ -f "$LIB_DIR/backup_config.sh" ]   && source "$LIB_DIR/backup_config.sh"

IDENTITY_STATE_DIR="${IDENTITY_STATE_DIR:-$WORKSPACE/.state}"
IDENTITY_BACKUP_STATE_FILE="$HEARTBEAT_DIR/identity-backup.json"
VAULT_BACKUP_STATE_FILE="$HEARTBEAT_DIR/vault-backup.json"
CONFIG_BACKUP_STATE_FILE="$HEARTBEAT_DIR/config-backup.json"

cmd_help() {
  cat <<EOF
heartbeatctl — manage the agent heartbeat.

Read:
  status [--json]         Print human or machine-readable state.
  logs   [-n N] [--json]  Tail logs/runs.jsonl. Default N=20.
  show                    Dump heartbeat.conf + installed crontab + agent.yml section.

Control:
  test   [--prompt "..."] Run one heartbeat now (trigger=manual).
  pause                   Comment crontab line, set enabled=false in agent.yml.
  resume                  Inverse of pause.
  reload                  Re-read agent.yml, regenerate conf + crontab, SIGHUP crond.
  kick-channel            Force-respawn the tmux session when Telegram chat ghosts.
  drop-plugin   <spec>    Remove a plugin spec from agent.yml.plugins[]
                          (e.g. caveman@JuliusBrussee). Then kick-channel to apply.

Mutate (all atomic with rollback against agent.yml.prev):
  set-interval  <Nm|Nh>
  set-prompt    "<str>"     (or pipe via stdin with no arg)
  set-notifier  <none|log|telegram>
  set-timeout   <seconds>
  set-retries   <0..5>

Backup:
  backup-identity [--configure-key <pubkey>] [--disable] [--dry-run] [--gc]
                          Snapshot identity (login, pairing, plugin config,
                          encrypted .env) to the 'backup/identity' branch
                          on the agent's fork. Idempotent. See
                          docs/superpowers/specs/2026-04-22-identity-backup-design.md.
  backup-vault    [--dry-run] [--gc]
                          Snapshot the vault's markdown to the 'backup/vault'
                          branch. Excludes Obsidian per-device config (.obsidian/
                          workspace*.json, cache, .trash, sync-conflict files).
                          Idempotent via sha256 over content + filenames.
  backup-config   [--dry-run] [--gc]
                          Snapshot agent.yml (plaintext config, no secrets) to
                          the 'backup/config' branch. Restored first by
                          setup.sh --restore-from-fork so the agent.yml is
                          available before identity + vault are pulled.

Exit codes:
  0  success
  1  validation error
  2  operational error (filesystem, yq, crond)

Spec: docs/superpowers/specs/2026-04-19-heartbeat-observability-cli-design.md
EOF
}

cmd_show() {
  echo "=== heartbeat.conf ($CONF_FILE) ==="
  if [ -f "$CONF_FILE" ]; then cat "$CONF_FILE"; else echo "(missing)"; fi
  echo
  echo "=== crontab ($CRONTAB_FILE) ==="
  if [ -f "$CRONTAB_FILE" ]; then cat "$CRONTAB_FILE"; else echo "(missing)"; fi
  echo
  echo "=== agent.yml :: features.heartbeat + notifications ==="
  if [ -f "$AGENT_YML" ]; then
    yq '{"features": {"heartbeat": .features.heartbeat}, "notifications": .notifications}' "$AGENT_YML"
  else
    echo "(missing)"
  fi
}

# Read a key from agent.yml, returning empty string on missing/null.
# Distinguishes "yq parsed OK but path is missing/null" (silent — caller
# falls back to its `// "default"`) from "yq itself errored" (loud — the
# yml is malformed and the user needs to know).
_yq() {
  local out err_log
  err_log=$(mktemp)
  if ! out=$(yq "${1}" "$AGENT_YML" 2>"$err_log"); then
    echo "heartbeatctl: yq failed reading '${1}' from $AGENT_YML:" >&2
    cat "$err_log" >&2
    rm -f "$err_log"
    return 1
  fi
  rm -f "$err_log"
  printf '%s' "$out" | sed 's/^null$//'
}

cmd_reload() {
  [ -f "$AGENT_YML" ] || { echo "heartbeatctl: $AGENT_YML missing" >&2; return 2; }

  local enabled interval timeout retries prompt channel cron
  # Use shell-level default for 'enabled' so yq boolean false is preserved
  enabled=$(_yq '.features.heartbeat.enabled')
  [ -z "$enabled" ] && enabled="true"
  interval=$(_yq '.features.heartbeat.interval // "30m"')
  timeout=$(_yq '.features.heartbeat.timeout // 300')
  retries=$(_yq '.features.heartbeat.retries // 1')
  prompt=$(_yq '.features.heartbeat.default_prompt // "Status check — return a short plain-text report (uptime, notable issues). No tool use; your stdout is forwarded verbatim to the notifier."')
  channel=$(_yq '.notifications.channel // "none"')

  # Validate + derive cron
  if ! cron=$(interval_to_cron "$interval" 2>&1); then
    echo "heartbeatctl: $cron" >&2
    return 1
  fi

  # Ensure destination dirs exist
  mkdir -p "$HEARTBEAT_DIR/logs"

  # Rewrite heartbeat.conf atomically
  local tmp_conf
  tmp_conf=$(mktemp)
  cat > "$tmp_conf" <<CONF
# Heartbeat — generated by \`heartbeatctl reload\`. Do not edit by hand.
HEARTBEAT_ENABLED="$enabled"
HEARTBEAT_INTERVAL="$interval"
HEARTBEAT_CRON="$cron"
HEARTBEAT_TIMEOUT="$timeout"
HEARTBEAT_RETRIES="$retries"
NOTIFY_SUCCESS_EVERY="1"
HEARTBEAT_PROMPT="$(printf '%s' "$prompt" | sed 's/"/\\"/g')"
NOTIFY_CHANNEL="$channel"
NOTIFY_BOT_TOKEN="\${NOTIFY_BOT_TOKEN:-}"
NOTIFY_CHAT_ID="\${NOTIFY_CHAT_ID:-}"
CONF
  if ! mv -f "$tmp_conf" "$CONF_FILE"; then
    rm -f "$tmp_conf"
    echo "heartbeatctl: failed to install $CONF_FILE" >&2
    return 2
  fi

  # Rewrite crontab atomically via tmp+mv on the same directory.
  # The default $CRONTAB_FILE is the workspace staging path
  # (.crontab.staging), which is agent-owned, so a sibling tmp file
  # is writable. The root-side sync loop in entrypoint.sh reads this
  # via cmp -s — without tmp+mv, a concurrent reader could observe a
  # partially-written file and copy garbage into /etc/crontabs/.
  local line
  if [ "$enabled" = "true" ]; then
    line="$cron /workspace/scripts/heartbeat/heartbeat.sh >> /workspace/scripts/heartbeat/logs/cron.log 2>&1"
  else
    line="# paused: $cron /workspace/scripts/heartbeat/heartbeat.sh >> /workspace/scripts/heartbeat/logs/cron.log 2>&1"
  fi
  # Optional second crontab line for scheduled identity backup
  local backup_line=""
  local bi_enabled bi_schedule
  bi_enabled=$(_yq '.features.identity_backup.enabled')
  bi_schedule=$(_yq '.features.identity_backup.schedule // "30 3 * * *"')
  if [ "$bi_enabled" = "true" ]; then
    backup_line="$bi_schedule /usr/local/bin/heartbeatctl backup-identity >> /workspace/scripts/heartbeat/logs/backup-identity.log 2>&1"
  fi

  # Optional third crontab line for scheduled vault backup. Default
  # cadence is hourly because the vault is the agent's working data
  # and changes much faster than identity (which is roughly static
  # post-setup). Override via vault.backup_schedule in agent.yml.
  local vault_backup_line=""
  local vault_enabled vault_backup_schedule
  vault_enabled=$(_yq '.vault.enabled')
  vault_backup_schedule=$(_yq '.vault.backup_schedule // "0 * * * *"')
  if [ "$vault_enabled" = "true" ]; then
    vault_backup_line="$vault_backup_schedule /usr/local/bin/heartbeatctl backup-vault >> /workspace/scripts/heartbeat/logs/backup-vault.log 2>&1"
  fi

  # Optional fourth crontab line for scheduled config backup. Same
  # cadence as identity (daily 03:30) because agent.yml only changes
  # via setup.sh --regenerate. Set features.config_backup.enabled=false
  # in agent.yml to opt out.
  local config_backup_line=""
  local cfg_enabled cfg_schedule
  cfg_enabled=$(_yq '.features.config_backup.enabled')
  [ -z "$cfg_enabled" ] && cfg_enabled="true"
  cfg_schedule=$(_yq '.features.config_backup.schedule // "30 3 * * *"')
  if [ "$cfg_enabled" = "true" ]; then
    config_backup_line="$cfg_schedule /usr/local/bin/heartbeatctl backup-config >> /workspace/scripts/heartbeat/logs/backup-config.log 2>&1"
  fi

  local tmp_crontab="${CRONTAB_FILE}.tmp"
  if ! cat > "$tmp_crontab" <<CT
# Cron for in-container agent heartbeat + identity/vault/config backup. Managed by heartbeatctl.
$line
${backup_line}
${vault_backup_line}
${config_backup_line}
CT
  then
    rm -f "$tmp_crontab"
    echo "heartbeatctl: failed to write $tmp_crontab" >&2
    return 2
  fi
  if ! mv -f "$tmp_crontab" "$CRONTAB_FILE"; then
    rm -f "$tmp_crontab"
    echo "heartbeatctl: failed to install $CRONTAB_FILE" >&2
    return 2
  fi

  # Do NOT SIGHUP busybox crond — unlike vixie/cronie, busybox crond
  # terminates on SIGHUP instead of reloading. Its scheduler rechecks
  # crontab mtimes on every minute tick and picks up changes on its own.
  # Expected lag to first tick with the new schedule: up to 60 seconds.

  echo "heartbeatctl: reloaded (interval=$interval cron='$cron' enabled=$enabled channel=$channel)"
}

_crond_pid() {
  # Best-effort: return pid of crond, empty if not running
  pgrep -x crond 2>/dev/null | head -1
}

_enrich_state() {
  # Read state.json, overlay crond {alive,pid}, emit to stdout
  local state_raw
  state_raw=$(cat "$STATE_FILE" 2>/dev/null || echo '{}')
  local pid alive
  pid=$(_crond_pid)
  if [ -n "$pid" ]; then alive=true; else alive=false; fi
  printf '%s' "$state_raw" | jq -c --arg pid "$pid" --argjson alive "$alive" '
    .crond = {alive:$alive, pid:($pid | if . == "" then null else tonumber end)}
  '
}

cmd_status() {
  [ -f "$STATE_FILE" ] || { echo "heartbeatctl: $STATE_FILE missing — has the heartbeat ever run? try 'heartbeatctl reload'" >&2; return 2; }
  local schema
  schema=$(jq -r '.schema // 0' "$STATE_FILE" 2>/dev/null || echo 0)
  if [ "$schema" != "1" ]; then
    echo "heartbeatctl: unknown state.json schema '$schema' — refusing to parse" >&2
    return 1
  fi

  local enriched
  enriched=$(_enrich_state)

  if [ "${1:-}" = "--json" ]; then
    printf '%s\n' "$enriched"
    return 0
  fi

  # Pretty
  printf '%s' "$enriched" | jq -r '
    "heartbeat: " + (if .enabled then "ENABLED" else "PAUSED" end)
    + "\n  interval: " + .interval + "   cron: " + .cron
    + "\n  prompt:   " + (.prompt | .[0:120] + (if length > 120 then "…" else "" end))
    + "\n  notifier: " + .notifier_channel
    + "\n  last run: " + .last_run.status + "  @ " + .last_run.ts + "  (" + (.last_run.duration_ms|tostring) + "ms, attempt " + (.last_run.attempt|tostring) + ")"
    + "\n  counters: runs=" + (.counters.total_runs|tostring)
      + " ok=" + (.counters.ok|tostring)
      + " timeout=" + (.counters.timeout|tostring)
      + " error=" + (.counters.error|tostring)
      + " streak_fail=" + (.counters.consecutive_failures|tostring)
      + (if .counters.success_rate_24h then "  24h=" + ((.counters.success_rate_24h*100|floor)|tostring) + "%" else "" end)
    + "\n  crond:    " + (if .crond.alive then "alive (pid " + (.crond.pid|tostring) + ")" else "DOWN" end)
    + "\n  updated:  " + .updated_at'
  echo

  # Tail of last 5 runs
  if [ -f "$RUNS_FILE" ]; then
    echo "recent runs:"
    tail -5 "$RUNS_FILE" | jq -r '"  " + .ts + "  " + .status + "  " + (.duration_ms|tostring) + "ms  " + (.prompt | .[0:60])'
  fi

  # Identity backup summary (non-fatal if state file missing)
  if [ -f "$IDENTITY_BACKUP_STATE_FILE" ]; then
    local bi_mode bi_commit bi_push
    bi_mode=$(jq -r '.mode // ""' "$IDENTITY_BACKUP_STATE_FILE" 2>/dev/null)
    bi_commit=$(jq -r '.last_commit // ""' "$IDENTITY_BACKUP_STATE_FILE" 2>/dev/null)
    bi_push=$(jq -r '.last_push // ""' "$IDENTITY_BACKUP_STATE_FILE" 2>/dev/null)
    echo
    echo "identity backup: mode=${bi_mode:-unknown} commit=${bi_commit:0:8} last_push=${bi_push:-never}"
    if [ "$bi_mode" = "partial" ]; then
      echo "  ⚠ partial mode — .env not encrypted. Run:"
      echo "    heartbeatctl backup-identity --configure-key <path|pubkey>"
    fi
  fi
}

cmd_logs() {
  local n=20 json=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -n) n="$2"; shift 2 ;;
      --json) json=true; shift ;;
      *) echo "logs: unknown flag '$1'" >&2; return 1 ;;
    esac
  done
  [ -f "$RUNS_FILE" ] || { echo "heartbeatctl: no runs yet"; return 0; }
  if [ "$json" = true ]; then
    tail -n "$n" "$RUNS_FILE"
  else
    printf '%-21s  %-8s  %-7s  %-5s  %s\n' "TS" "STATUS" "DUR" "ATTMPT" "PROMPT"
    tail -n "$n" "$RUNS_FILE" | jq -r '
      [.ts, .status, ((.duration_ms|tostring)+"ms"), (.attempt|tostring), (.prompt|.[0:60])]
      | @tsv' | awk -F'\t' '{printf "%-21s  %-8s  %-7s  %-5s  %s\n", $1,$2,$3,$4,$5}'
  fi
}

cmd_pause() {
  local prev; prev="$AGENT_YML.prev"
  cp "$AGENT_YML" "$prev"
  yq -i '.features.heartbeat.enabled = false' "$AGENT_YML" || {
    cp "$prev" "$AGENT_YML"; rm -f "$prev"; echo "pause: yq failed" >&2; return 2
  }
  if ! cmd_reload; then
    cp "$prev" "$AGENT_YML"; rm -f "$prev"
    cmd_reload >/dev/null 2>&1 || true
    return 2
  fi
  rm -f "$prev"
  echo "heartbeatctl: paused"
}

cmd_resume() {
  local prev; prev="$AGENT_YML.prev"
  cp "$AGENT_YML" "$prev"
  yq -i '.features.heartbeat.enabled = true' "$AGENT_YML" || {
    cp "$prev" "$AGENT_YML"; rm -f "$prev"; echo "resume: yq failed" >&2; return 2
  }
  if ! cmd_reload; then
    cp "$prev" "$AGENT_YML"; rm -f "$prev"
    cmd_reload >/dev/null 2>&1 || true
    return 2
  fi
  rm -f "$prev"
  echo "heartbeatctl: resumed"
}

# _mutate EXPR VALIDATOR VALUE
# Runs validator(value) first; if 0, backs up agent.yml, applies yq -i EXPR,
# runs reload, and on any failure restores agent.yml and reloads with the
# prior state. EXPR uses strenv(V) to read the value.
_mutate() {
  local expr="$1" validator="$2" value="$3"
  if ! "$validator" "$value"; then return 1; fi
  local prev="$AGENT_YML.prev"
  cp "$AGENT_YML" "$prev"
  if ! V="$value" yq -i "$expr" "$AGENT_YML"; then
    cp "$prev" "$AGENT_YML"; rm -f "$prev"
    echo "heartbeatctl: yq mutation failed" >&2; return 2
  fi
  if ! cmd_reload; then
    cp "$prev" "$AGENT_YML"; rm -f "$prev"
    cmd_reload >/dev/null 2>&1 || true
    echo "heartbeatctl: reload failed after mutation — rolled back" >&2
    return 2
  fi
  rm -f "$prev"
}

_v_interval() {
  interval_to_cron "$1" >/dev/null 2>&1 || { echo "invalid interval: $1 (see 'heartbeatctl help')" >&2; return 1; }
}
_v_notifier() {
  case "$1" in none|log|telegram) return 0 ;;
    *) echo "invalid notifier: $1 (none|log|telegram)" >&2; return 1 ;;
  esac
}
_v_timeout() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]] && [ "$1" -ge 10 ] || { echo "timeout must be integer >= 10" >&2; return 1; }
}
_v_retries() {
  [[ "$1" =~ ^[0-5]$ ]] || { echo "retries must be integer 0..5" >&2; return 1; }
}
_v_prompt() {
  local len=${#1}
  [ "$len" -gt 0 ] && [ "$len" -le 4000 ] || { echo "prompt must be 1..4000 chars" >&2; return 1; }
}

cmd_set_interval() { _mutate '.features.heartbeat.interval = strenv(V)' _v_interval "$1"; }
cmd_set_notifier() { _mutate '.notifications.channel = strenv(V)'     _v_notifier "$1"; }
cmd_set_timeout()  { _mutate '.features.heartbeat.timeout = (strenv(V)|tonumber)' _v_timeout "$1"; }
cmd_set_retries()  { _mutate '.features.heartbeat.retries = (strenv(V)|tonumber)' _v_retries "$1"; }

cmd_set_prompt() {
  local v="${1:-}"
  if [ -z "$v" ] && [ ! -t 0 ]; then v=$(cat); fi
  _mutate '.features.heartbeat.default_prompt = strenv(V)' _v_prompt "$v"
  # Warn if telegram without secrets
  if [ "$(yq -r '.notifications.channel' "$AGENT_YML")" = "telegram" ]; then
    if ! grep -q '^NOTIFY_BOT_TOKEN=' "$WORKSPACE/.env" 2>/dev/null || \
       ! grep -q '^NOTIFY_CHAT_ID=' "$WORKSPACE/.env" 2>/dev/null; then
      echo "heartbeatctl: WARN — notifications.channel=telegram but .env missing NOTIFY_BOT_TOKEN/NOTIFY_CHAT_ID" >&2
    fi
  fi
}

cmd_test() {
  local prompt=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --prompt) prompt="$2"; shift 2 ;;
      *) echo "test: unknown flag '$1'" >&2; return 1 ;;
    esac
  done
  local runner="$HEARTBEAT_DIR/heartbeat.sh"
  [ -x "$runner" ] || { echo "heartbeatctl: $runner missing or not executable" >&2; return 2; }
  HEARTBEAT_TRIGGER=manual \
  HEARTBEAT_STATE_LIB="${HEARTBEAT_STATE_LIB:-$LIB_DIR/state.sh}" \
    bash "$runner" ${prompt:+--prompt "$prompt"}
}

# kick-channel — force-respawn the tmux session when the Telegram plugin
# stops forwarding messages to claude. The bug is upstream in the MCP
# stdio routing between claude-plugins-official/telegram and claude
# itself: bun stays alive and keeps polling Telegram, but its
# `notifications/claude/channel` messages don't reach the session.
# This command kills the tmux session; start_services.sh watchdog
# respawns it within ~2 seconds with a fresh plugin attachment.
cmd_backup_identity() {
  local mode="run"
  local configure_key=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --configure-key) shift; configure_key="${1:-}"; mode="configure"; shift ;;
      --disable)       mode="disable"; shift ;;
      --dry-run)       mode="dry-run"; shift ;;
      --gc)            mode="gc"; shift ;;
      -h|--help)
        cat <<EOF
Usage: heartbeatctl backup-identity [flags]

Flags:
  --configure-key <path|pubkey-string>   Set backup.identity.recipient, trigger backup.
  --disable                              Set features.identity_backup.enabled=false.
  --dry-run                              Stage + diff without push.
  --gc                                   Run 'git gc' on the local clone before push.
  (no flags)                             Default: run the backup primitive.
EOF
        return 0 ;;
      *) echo "backup-identity: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  [ -d "$IDENTITY_STATE_DIR" ] || {
    echo "backup-identity: no state dir at $IDENTITY_STATE_DIR — nothing to back up yet"
    return 0
  }

  case "$mode" in
    run)        _bi_run ;;
    configure)  _bi_configure_key "$configure_key" ;;
    disable)    _bi_disable ;;
    dry-run)    _bi_run --dry-run ;;
    gc)         _bi_gc_then_run ;;
  esac
}

_bi_run() {
  local dry_run=0
  [ "${1:-}" = "--dry-run" ] && dry_run=1

  local any=0 path
  while IFS= read -r path; do
    [ -e "$IDENTITY_STATE_DIR/$path" ] && { any=1; break; }
  done < <(identity_whitelist "$IDENTITY_STATE_DIR")
  if [ "$any" -eq 0 ]; then
    echo "backup-identity: no identity files yet, skipping"
    return 0
  fi

  local fork_url recipient
  fork_url=$(_yq '.scaffold.fork.url')
  recipient=$(_yq '.backup.identity.recipient')
  [ "$recipient" = "null" ] && recipient=""

  local current_hash last_hash
  current_hash=$(identity_hash "$IDENTITY_STATE_DIR" "$recipient")
  last_hash=$(identity_last_hash "$IDENTITY_BACKUP_STATE_FILE")

  if [ -n "$last_hash" ] && [ "$current_hash" = "$last_hash" ]; then
    echo "backup-identity: no changes since last backup (hash $last_hash)"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    echo "backup-identity: dry-run (no push) — would change from ${last_hash:-<none>} to $current_hash"
    return 0
  fi

  if [ -z "$fork_url" ]; then
    echo "backup-identity: agent.yml has no scaffold.fork.url — fork-less agent, nothing to back up to"
    return 0
  fi

  local clone_dir result sha mode
  clone_dir=$(identity_prepare_clone "$fork_url")
  if ! result=$(identity_commit_and_push "$clone_dir" "$IDENTITY_STATE_DIR" "$recipient"); then
    return $?
  fi
  sha="${result%% *}"
  mode="${result##* }"

  if [ "$sha" = "-" ]; then
    echo "backup-identity: no changes after stage-diff (hash $current_hash)"
    identity_write_state "$IDENTITY_BACKUP_STATE_FILE" "$current_hash" "$mode" "" ""
    return 0
  fi

  identity_write_state "$IDENTITY_BACKUP_STATE_FILE" "$current_hash" "$mode" "$sha" \
    "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf 'backup-identity: %s pushed (%s)\n' "${sha:0:8}" "$mode"
}

_bi_configure_key() {
  local arg="$1"
  local key

  if [ -f "$arg" ]; then
    key=$(tr -d '\r\n' < "$arg")
  else
    key="$arg"
  fi

  if ! [[ "$key" =~ ^(ssh-ed25519|ssh-rsa)\  ]]; then
    echo "backup-identity: invalid key '$arg' — must be an ssh-ed25519 or ssh-rsa public key" >&2
    return 1
  fi

  yq -i ".backup.identity.recipient = \"$key\"" "$AGENT_YML" || {
    echo "backup-identity: failed to update $AGENT_YML" >&2
    return 2
  }
  echo "backup-identity: recipient updated"

  _bi_run
}
_bi_disable() {
  yq -i '.features.identity_backup.enabled = false' "$AGENT_YML" || return 2
  echo "backup-identity: identity_backup disabled in agent.yml"
  cmd_reload >/dev/null 2>&1 || true
}

_bi_gc_then_run() {
  local fork_url
  fork_url=$(_yq '.scaffold.fork.url')
  [ -z "$fork_url" ] && { echo "backup-identity: no fork url"; return 0; }
  local clone_dir
  clone_dir=$(identity_prepare_clone "$fork_url")
  (cd "$clone_dir" && git gc --prune=now --aggressive >/dev/null 2>&1) || true
  _bi_run
}

# Vault backup primitive — analogous to cmd_backup_identity. Snapshots
# the markdown subset of the configured vault to a 'backup/vault' orphan
# branch on the agent's fork. Idempotent.
cmd_backup_vault() {
  local mode="run"
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) mode="dry-run"; shift ;;
      --gc)      mode="gc"; shift ;;
      -h|--help)
        cat <<EOF
Usage: heartbeatctl backup-vault [flags]

Flags:
  --dry-run   Stage + hash without push.
  --gc        Run 'git gc' on the local clone before push.
  (no flags)  Default: run the vault backup primitive.
EOF
        return 0 ;;
      *) echo "backup-vault: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  case "$mode" in
    run)     _bv_run ;;
    dry-run) _bv_run --dry-run ;;
    gc)      _bv_gc_then_run ;;
  esac
}

# Resolve the vault directory the agent should back up. Tests override
# via $VAULT_BACKUP_DIR; production reads it from agent.yml via
# vault_resolve_root.
_bv_dir() {
  if [ -n "${VAULT_BACKUP_DIR:-}" ]; then
    printf '%s\n' "$VAULT_BACKUP_DIR"
    return
  fi
  command -v vault_resolve_root >/dev/null 2>&1 || return 0
  vault_resolve_root "$AGENT_YML"
}

_bv_run() {
  local dry_run=0
  [ "${1:-}" = "--dry-run" ] && dry_run=1

  local vault_dir
  vault_dir=$(_bv_dir)
  if [ -z "$vault_dir" ]; then
    echo "backup-vault: vault not enabled in agent.yml — nothing to back up"
    return 0
  fi
  if [ ! -d "$vault_dir" ]; then
    echo "backup-vault: vault dir $vault_dir does not exist yet — skipping"
    return 0
  fi

  local fork_url
  fork_url=$(_yq '.scaffold.fork.url')

  local current_hash last_hash
  current_hash=$(vault_hash "$vault_dir")
  last_hash=$(vault_last_hash "$VAULT_BACKUP_STATE_FILE")

  if [ -n "$last_hash" ] && [ "$current_hash" = "$last_hash" ]; then
    echo "backup-vault: no changes since last backup (hash $last_hash)"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    echo "backup-vault: dry-run (no push) — would change from ${last_hash:-<none>} to $current_hash"
    return 0
  fi

  if [ -z "$fork_url" ]; then
    echo "backup-vault: agent.yml has no scaffold.fork.url — nothing to back up to"
    return 0
  fi

  local clone_dir sha
  clone_dir=$(vault_prepare_clone "$fork_url")
  if ! sha=$(vault_commit_and_push "$clone_dir" "$vault_dir"); then
    return $?
  fi

  if [ "$sha" = "-" ]; then
    echo "backup-vault: no changes after stage-diff (hash $current_hash)"
    vault_write_state "$VAULT_BACKUP_STATE_FILE" "$current_hash" "" ""
    return 0
  fi

  vault_write_state "$VAULT_BACKUP_STATE_FILE" "$current_hash" "$sha" \
    "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf 'backup-vault: %s pushed\n' "${sha:0:8}"
}

_bv_gc_then_run() {
  local fork_url
  fork_url=$(_yq '.scaffold.fork.url')
  [ -z "$fork_url" ] && { echo "backup-vault: no fork url"; return 0; }
  local clone_dir
  clone_dir=$(vault_prepare_clone "$fork_url")
  (cd "$clone_dir" && git gc --prune=now --aggressive >/dev/null 2>&1) || true
  _bv_run
}

# Config backup primitive — snapshots agent.yml to backup/config.
cmd_backup_config() {
  local mode="run"
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) mode="dry-run"; shift ;;
      --gc)      mode="gc"; shift ;;
      -h|--help)
        cat <<EOF
Usage: heartbeatctl backup-config [flags]

Flags:
  --dry-run   Stage + hash without push.
  --gc        Run 'git gc' on the local clone before push.
  (no flags)  Default: run the config backup primitive.
EOF
        return 0 ;;
      *) echo "backup-config: unknown flag: $1" >&2; return 1 ;;
    esac
  done

  case "$mode" in
    run)     _bc_run ;;
    dry-run) _bc_run --dry-run ;;
    gc)      _bc_gc_then_run ;;
  esac
}

_bc_run() {
  local dry_run=0
  [ "${1:-}" = "--dry-run" ] && dry_run=1

  if [ ! -f "$AGENT_YML" ]; then
    echo "backup-config: $AGENT_YML missing — nothing to back up"
    return 0
  fi

  local fork_url
  fork_url=$(_yq '.scaffold.fork.url')

  local current_hash last_hash
  current_hash=$(config_hash "$AGENT_YML")
  last_hash=$(config_last_hash "$CONFIG_BACKUP_STATE_FILE")

  if [ -n "$last_hash" ] && [ "$current_hash" = "$last_hash" ]; then
    echo "backup-config: no changes since last backup (hash $last_hash)"
    return 0
  fi

  if [ "$dry_run" -eq 1 ]; then
    echo "backup-config: dry-run (no push) — would change from ${last_hash:-<none>} to $current_hash"
    return 0
  fi

  if [ -z "$fork_url" ]; then
    echo "backup-config: agent.yml has no scaffold.fork.url — nothing to back up to"
    return 0
  fi

  local clone_dir sha
  clone_dir=$(config_prepare_clone "$fork_url")
  if ! sha=$(config_commit_and_push "$clone_dir" "$AGENT_YML"); then
    return $?
  fi

  if [ "$sha" = "-" ]; then
    echo "backup-config: no changes after stage-diff (hash $current_hash)"
    config_write_state "$CONFIG_BACKUP_STATE_FILE" "$current_hash" "" ""
    return 0
  fi

  config_write_state "$CONFIG_BACKUP_STATE_FILE" "$current_hash" "$sha" \
    "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf 'backup-config: %s pushed\n' "${sha:0:8}"
}

_bc_gc_then_run() {
  local fork_url
  fork_url=$(_yq '.scaffold.fork.url')
  [ -z "$fork_url" ] && { echo "backup-config: no fork url"; return 0; }
  local clone_dir
  clone_dir=$(config_prepare_clone "$fork_url")
  (cd "$clone_dir" && git gc --prune=now --aggressive >/dev/null 2>&1) || true
  _bc_run
}

cmd_kick_channel() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "heartbeatctl: tmux not available — cannot kick session" >&2
    return 2
  fi
  if ! tmux has-session -t agent 2>/dev/null; then
    echo "heartbeatctl: tmux session 'agent' not found — nothing to kick" >&2
    return 2
  fi
  tmux kill-session -t agent
  echo "heartbeatctl: killed tmux session 'agent' — watchdog will respawn in ~2s"
}

# drop-plugin <spec> — remove a plugin spec from agent.yml.plugins[].
# Idempotent (no-op if spec not in list). Atomic with backup/restore on
# yq failure (matches cmd_pause/cmd_resume pattern). Does NOT auto-kick
# the channel — the caller decides when to recycle the session, since
# the new plugins[] is consumed by ensure_all_plugins_installed on the
# next watchdog respawn either way.
cmd_drop_plugin() {
  local spec="${1:-}"
  if [ -z "$spec" ]; then
    echo "drop-plugin: missing <spec> (e.g. caveman@JuliusBrussee)" >&2
    return 1
  fi
  [ -f "$AGENT_YML" ] || { echo "drop-plugin: $AGENT_YML missing" >&2; return 2; }
  # yq (go-yq, mikefarah) doesn't have jq's `index()`; use `contains`
  # against a single-element array. `.plugins // []` makes the path safe
  # when the field is absent. Prints "true" or "false".
  local present
  present=$(V="$spec" yq '(.plugins // []) | contains([strenv(V)])' "$AGENT_YML" 2>/dev/null)
  if [ "$present" != "true" ]; then
    echo "heartbeatctl: $spec not in agent.yml.plugins — nothing to drop"
    return 0
  fi
  local prev="$AGENT_YML.prev"
  cp "$AGENT_YML" "$prev"
  if ! V="$spec" yq -i '.plugins -= [strenv(V)]' "$AGENT_YML"; then
    cp "$prev" "$AGENT_YML"; rm -f "$prev"
    echo "drop-plugin: yq mutation failed; agent.yml restored from backup" >&2
    return 2
  fi
  rm -f "$prev"
  echo "heartbeatctl: dropped $spec from agent.yml — run 'heartbeatctl kick-channel' to apply"
}

main() {
  local sub="${1:-help}"; shift || true
  case "$sub" in
    help|-h|--help|"") cmd_help ;;
    show) cmd_show "$@" ;;
    reload) cmd_reload "$@" ;;
    status) cmd_status "$@" ;;
    logs)   cmd_logs   "$@" ;;
    pause)  cmd_pause ;;
    resume) cmd_resume ;;
    test)   cmd_test "$@" ;;
    kick-channel) cmd_kick_channel ;;
    drop-plugin)  cmd_drop_plugin  "${1:-}" ;;
    backup-identity) cmd_backup_identity "$@" ;;
    backup-vault)    cmd_backup_vault "$@" ;;
    backup-config)   cmd_backup_config "$@" ;;
    set-interval) cmd_set_interval "${1:-}" ;;
    set-prompt)   cmd_set_prompt   "${1:-}" ;;
    set-notifier) cmd_set_notifier "${1:-}" ;;
    set-timeout)  cmd_set_timeout  "${1:-}" ;;
    set-retries)  cmd_set_retries  "${1:-}" ;;
    *) echo "heartbeatctl: unknown command '$sub' (see 'heartbeatctl help')" >&2; exit 1 ;;
  esac
}

main "$@"
